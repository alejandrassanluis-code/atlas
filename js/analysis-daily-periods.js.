/* ==========================================================
   ATLAS
   analysis-daily-periods.js
   Actividad real y ajustes económicos del mes
========================================================== */

const AtlasAnalysisDailyPeriods = {

    initialized:
        false,

    validMonth(value) {

        return /^\d{4}-\d{2}$/.test(
            String(value || "")
        );

    },

    number(value) {

        const result =
            Number(value);

        return Number.isFinite(result)
            ? result
            : 0;

    },

    realMonth(movement) {

        const monthKey =
            String(
                movement?.date || ""
            ).slice(
                0,
                7
            );

        return this.validMonth(
            monthKey
        )
            ? monthKey
            : "";

    },

    economicMonth(movement) {

        const candidates = [

            movement?.periodMonth,

            movement?.economicMonth,

            movement?.imputedMonth,

            this.realMonth(
                movement
            )

        ];

        return (
            candidates.find(
                value =>
                    this.validMonth(
                        value
                    )
            ) ||
            ""
        );

    },

    movementKind(movement) {

        if (
            movement?.kind ===
                "debt_payment" ||
            movement?.type ===
                "debt_payment"
        ) {

            return "debt_payment";

        }

        if (
            movement?.kind ===
                "reimbursement" ||
            movement?.type ===
                "reimbursement"
        ) {

            return "reimbursement";

        }

        return (
            movement?.kind ||
            movement?.type ||
            ""
        );

    },

    movementLabel(movement) {

        const labels = {

            income:
                "Ingreso",

            expense:
                "Gasto",

            reimbursement:
                "Reembolso",

            investment:
                "Inversión",

            transfer:
                "Traspaso",

            debt_payment:
                "Pago de deuda"

        };

        return (
            movement?.category ||
            labels[
                this.movementKind(
                    movement
                )
            ] ||
            "Movimiento"
        );

    },

    movements(data) {

        return Array.isArray(
            data?.movements
        )
            ? data.movements
            : [];

    },

    economicEffect(movement) {

        const amount =
            this.number(
                movement?.amount
            );

        const kind =
            this.movementKind(
                movement
            );

        if (
            kind === "income" ||
            kind === "reimbursement"
        ) {

            return amount;

        }

        if (
            kind === "expense" ||
            kind === "investment"
        ) {

            return -amount;

        }

        return 0;

    },

    effectColor(value) {

        return this.number(value) >= 0
            ? "var(--color-success)"
            : "var(--color-danger)";

    },

    adjustmentMovements(
        data,
        monthKey
    ) {

        return this.movements(data)
            .filter(
                movement =>
                    this.economicMonth(
                        movement
                    ) === monthKey
            )
            .filter(
                movement =>
                    this.realMonth(
                        movement
                    ) !== monthKey
            )
            .filter(
                movement => {

                    const kind =
                        this.movementKind(
                            movement
                        );

                    return [
                        "income",
                        "expense",
                        "reimbursement",
                        "investment"
                    ].includes(kind);

                }
            )
            .sort(
                (
                    first,
                    second
                ) => {

                    const dateComparison =
                        String(
                            second.date || ""
                        ).localeCompare(
                            String(
                                first.date || ""
                            )
                        );

                    if (
                        dateComparison !== 0
                    ) {

                        return dateComparison;

                    }

                    return String(
                        second.createdAt || ""
                    ).localeCompare(
                        String(
                            first.createdAt || ""
                        )
                    );

                }
            );

    },

    median(values) {

        const list =
            values
                .map(
                    value =>
                        this.number(
                            value
                        )
                )
                .sort(
                    (
                        first,
                        second
                    ) =>
                        first -
                        second
                );

        if (
            list.length === 0
        ) {

            return 0;

        }

        const middle =
            Math.floor(
                list.length /
                2
            );

        if (
            list.length % 2 === 0
        ) {

            return (
                list[
                    middle - 1
                ] +
                list[
                    middle
                ]
            ) / 2;

        }

        return list[middle];

    },

    realActivity(
        data,
        monthKey
    ) {

        const movements =
            this.movements(data)
                .filter(
                    movement =>
                        this.realMonth(
                            movement
                        ) === monthKey
                );

        const activeDays =
            new Set(
                movements
                    .map(
                        movement =>
                            String(
                                movement.date ||
                                ""
                            )
                    )
                    .filter(Boolean)
            ).size;

        const expenseAmounts =
            movements
                .filter(
                    movement =>
                        this.movementKind(
                            movement
                        ) === "expense"
                )
                .map(
                    movement =>
                        this.number(
                            movement.amount
                        )
                );

        const totalExpenses =
            expenseAmounts.reduce(
                (
                    total,
                    amount
                ) =>
                    total +
                    amount,
                0
            );

        return {

            movements:
                movements.length,

            activeDays,

            averageExpense:
                expenseAmounts.length > 0
                    ? (
                        totalExpenses /
                        expenseAmounts.length
                    )
                    : 0,

            medianExpense:
                this.median(
                    expenseAmounts
                )

        };

    },

    realActivityPanel(
        data,
        monthKey
    ) {

        const activity =
            this.realActivity(
                data,
                monthKey
            );

        const rows = [

            {
                label:
                    "Movimientos reales",

                value:
                    activity.movements
            },

            {
                label:
                    "Días con actividad",

                value:
                    activity.activeDays
            },

            {
                label:
                    "Gasto medio",

                value:
                    AtlasUI.formatCurrency(
                        activity.averageExpense
                    )
            },

            {
                label:
                    "Gasto mediano",

                value:
                    AtlasUI.formatCurrency(
                        activity.medianExpense
                    )
            }

        ];

        return `

            <details
                class="
                    panel
                    atlas-analysis-panel
                    atlas-analysis-details
                "
                data-analysis-panel="monthly-activity"
                ${AtlasAnalysisUI.openAttribute(
                    "monthly-activity"
                )}
            >

                <summary>

                    <div>

                        <strong>
                            Actividad real del mes
                        </strong>

                        <small>
                            Operaciones según su fecha real
                        </small>

                    </div>

                    <span>
                        +
                    </span>

                </summary>

                <div
                    class="
                        atlas-analysis-details-content
                    "
                >

                    <div
                        class="
                            atlas-analysis-facts
                        "
                    >

                        ${rows
                            .map(
                                row => `

                                    <div>

                                        <small>
                                            ${AtlasUI.escapeHtml(
                                                row.label
                                            )}
                                        </small>

                                        <strong>
                                            ${row.value}
                                        </strong>

                                    </div>

                                `
                            )
                            .join("")}

                    </div>

                </div>

            </details>

        `;

    },

    adjustmentRow(movement) {

        const effect =
            this.economicEffect(
                movement
            );

        const realMonth =
            this.realMonth(
                movement
            );

        const economicMonth =
            this.economicMonth(
                movement
            );

        return `

            <article
                class="
                    atlas-analysis-economic-adjustment
                "
            >

                <div>

                    <strong>
                        ${AtlasUI.escapeHtml(
                            this.movementLabel(
                                movement
                            )
                        )}
                    </strong>

                    <small>
                        Fecha real:
                        ${AtlasUI.formatMovementDate(
                            movement.date
                        )}
                    </small>

                    <small>
                        Procede de
                        ${AtlasUI.formatMonthKey(
                            realMonth
                        )}
                        · imputado a
                        ${AtlasUI.formatMonthKey(
                            economicMonth
                        )}
                    </small>

                    ${
                        movement.note
                            ? `

                                <small>
                                    ${AtlasUI.escapeHtml(
                                        movement.note
                                    )}
                                </small>

                            `
                            : ""
                    }

                </div>

                <strong
                    style="
                        color:
                            ${this.effectColor(
                                effect
                            )};
                    "
                >
                    ${
                        effect >= 0
                            ? "+"
                            : "−"
                    }${AtlasUI.formatCurrency(
                        Math.abs(
                            effect
                        )
                    )}
                </strong>

            </article>

        `;

    },

    adjustmentsPanel(
        data,
        monthKey
    ) {

        const adjustments =
            this.adjustmentMovements(
                data,
                monthKey
            );

        if (
            adjustments.length === 0
        ) {

            return "";

        }

        const total =
            adjustments.reduce(
                (
                    sum,
                    movement
                ) =>
                    sum +
                    this.economicEffect(
                        movement
                    ),
                0
            );

        return `

            <section
                class="
                    panel
                    atlas-analysis-panel
                    atlas-analysis-economic-adjustments
                "
            >

                ${AtlasAnalysisUI.panelHeader(
                    "Ajustes económicos del mes",
                    "Movimientos imputados a este mes cuya fecha real pertenece a otro periodo.",
                    `

                        <strong
                            style="
                                color:
                                    ${this.effectColor(
                                        total
                                    )};
                                white-space:
                                    nowrap;
                            "
                        >
                            ${
                                total >= 0
                                    ? "+"
                                    : "−"
                            }${AtlasUI.formatCurrency(
                                Math.abs(
                                    total
                                )
                            )}
                        </strong>

                    `
                )}

                <div
                    class="
                        atlas-analysis-economic-adjustment-list
                    "
                >

                    ${adjustments
                        .map(
                            movement =>
                                this.adjustmentRow(
                                    movement
                                )
                        )
                        .join("")}

                </div>

            </section>

        `;

    },

    installStyles() {

        const previous =
            document.getElementById(
                "atlas-analysis-daily-period-styles"
            );

        if (previous) {

            previous.remove();

        }

        const style =
            document.createElement(
                "style"
            );

        style.id =
            "atlas-analysis-daily-period-styles";

        style.textContent = `

            .atlas-analysis-economic-adjustments {
                border-color:
                    rgba(
                        77,
                        163,
                        255,
                        0.23
                    );
                background:
                    rgba(
                        77,
                        163,
                        255,
                        0.055
                    );
            }

            .atlas-analysis-economic-adjustment-list {
                display: grid;
                margin-top: 12px;
            }

            .atlas-analysis-economic-adjustment {
                display: flex;
                align-items: flex-start;
                justify-content:
                    space-between;
                gap: 14px;
                padding:
                    13px
                    0;
                border-bottom:
                    1px solid
                    rgba(
                        145,
                        164,
                        202,
                        0.1
                    );
            }

            .atlas-analysis-economic-adjustment:last-child {
                border-bottom: 0;
            }

            .atlas-analysis-economic-adjustment > div {
                min-width: 0;
            }

            .atlas-analysis-economic-adjustment strong,
            .atlas-analysis-economic-adjustment small {
                display: block;
            }

            .atlas-analysis-economic-adjustment > div > strong {
                font-size: 12px;
                overflow-wrap: anywhere;
            }

            .atlas-analysis-economic-adjustment small {
                margin-top: 4px;
                color:
                    var(
                        --color-text-muted
                    );
                font-size: 9px;
                line-height: 1.4;
                overflow-wrap: anywhere;
            }

            .atlas-analysis-economic-adjustment
            > strong {
                flex:
                    0
                    0
                    auto;
                font-size: 13px;
                white-space: nowrap;
            }

        `;

        document.head.appendChild(
            style
        );

    },

    install() {

        if (
            this.initialized ||
            typeof AtlasAnalysisUI ===
                "undefined" ||
            typeof AtlasAnalysisUI
                .monthlyView !==
                "function"
        ) {

            return;

        }

        this.initialized =
            true;

        this.installStyles();

        const originalMonthlyView =
            AtlasAnalysisUI
                .monthlyView
                .bind(
                    AtlasAnalysisUI
                );

        AtlasAnalysisUI.monthlyView = (
            data,
            options = {}
        ) => {

            const monthKey =
                options.analysisMonth ||
                options.currentMonth ||
                AtlasCalculations
                    .monthKey();

            const originalActivityPanel =
                AtlasAnalysisUI
                    .activityPanel;

            AtlasAnalysisUI.activityPanel =
                () =>
                    this.realActivityPanel(
                        data,
                        monthKey
                    );

            let content = "";

            try {

                content =
                    originalMonthlyView(
                        data,
                        options
                    );

            } finally {

                AtlasAnalysisUI.activityPanel =
                    originalActivityPanel;

            }

            return `

                ${content}

                ${this.adjustmentsPanel(
                    data,
                    monthKey
                )}

            `;

        };

    }

};

AtlasAnalysisDailyPeriods.install();
